rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global safety catch-all: deny all by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper: Is the client authenticated?
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper: Does the authenticated client match the specified userId?
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // 1. users/{uid}
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isOwner(userId);
      allow delete: if false;
    }

    // 2. usernames/{username}
    match /usernames/{username} {
      allow read: if true; // Public read access for username availability checks
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      // Allow updates/merges if the user owns the username (needed during syncUserToFirestore)
      allow update: if isAuthenticated() && 
                    resource.data.uid == request.auth.uid && 
                    request.resource.data.uid == request.auth.uid;
      allow delete: if false;
    }

    // 3. settings/{uid}
    match /settings/{userId} {
      allow read, write: if isOwner(userId);
    }

    // 4. studyStats/{uid}
    match /studyStats/{userId} {
      allow read, write: if isOwner(userId);
    }

    // 5. friendships/{friendshipId}
    match /friendships/{friendshipId} {
      allow get: if isAuthenticated() && (resource == null || request.auth.uid in resource.data.uids);
      allow list: if isAuthenticated() && request.auth.uid in resource.data.uids;
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.uids;
      allow update: if isAuthenticated() && 
                    (resource != null && request.auth.uid in resource.data.uids) && 
                    (request.resource.data.uids != null && request.auth.uid in request.resource.data.uids);
      allow delete: if isAuthenticated() && (resource != null && request.auth.uid in resource.data.uids);
    }

    // 6. friendRequests/{requestId}
    match /friendRequests/{requestId} {
      allow get: if isAuthenticated() && (
        (resource == null) || 
        (request.auth.uid == resource.data.senderId || request.auth.uid == resource.data.receiverId)
      );
      allow list: if isAuthenticated() && (
        (request.auth.uid == resource.data.senderId || request.auth.uid == resource.data.receiverId)
      );
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.senderId;
      allow update, delete: if isAuthenticated() && (
        (resource == null) || 
        (request.auth.uid == resource.data.senderId || request.auth.uid == resource.data.receiverId)
      );
    }

    // 7. notifications/{notificationId}
    match /notifications/{notificationId} {
      allow get: if isAuthenticated() && (
        (resource == null) || 
        (request.auth.uid == resource.data.userId)
      );
      allow list: if isAuthenticated() && (
        (request.auth.uid == resource.data.userId)
      );
      allow create: if isAuthenticated(); // Allowed so users can send milestone notifications to friends
      allow update, delete: if isAuthenticated() && (
        (resource == null) || 
        (request.auth.uid == resource.data.userId)
      );
    }

    // 8. activities/{activityId}
    match /activities/{activityId} {
      allow get, list: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.userId;
      allow update, delete: if isAuthenticated() && (
        (resource == null) || 
        (request.auth.uid == resource.data.userId)
      );
    }

    // 9. leaderboards/{docId}
    match /leaderboards/{docId} {
      allow read: if true; // Publicly readable
      allow write: if false; // Only writable by server/admin functions (or disabled on clients)
    }

    // 10. users/{userId}/resources/{moduleId}/{document=**}
    match /users/{userId}/resources/{moduleId}/{document=**} {
      allow read, write: if isOwner(userId);
    }

    // 11. device_links/{code} for native Android Google Auth pairing
    match /device_links/{code} {
      allow read, write: if true;
    }

    // 12. auth_sessions/{sessionId} for iframe popup-to-parent communication bypass
    match /auth_sessions/{sessionId} {
      allow read, write: if true;
    }
  }
}
