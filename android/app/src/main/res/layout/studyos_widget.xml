<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@drawable/studyos_widget_background"
    android:padding="14dp"
    android:gravity="center_vertical">

    <!-- Icon Container / Visual Avatar badge -->
    <LinearLayout
        android:layout_width="54dp"
        android:layout_height="54dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/studyos_widget_badge_bg"
        android:layout_marginEnd="12dp">

        <TextView
            android:id="@+id/widget_avatar_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🐱"
            android:textSize="26sp" />
    </LinearLayout>

    <!-- Main Content Area -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center_vertical">

        <!-- Small Title Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="2dp">

            <TextView
                android:id="@+id/widget_brand"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="STUDYOS COMPANION"
                android:textColor="#3B82F6"
                android:textSize="9sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-condensed" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <!-- Mini pill indicator showing status (e.g. ONLINE or SYNCED) -->
            <TextView
                android:id="@+id/widget_pstatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="• SYNCED"
                android:textColor="#10B981"
                android:textSize="8sp"
                android:textStyle="bold"
                android:layout_marginStart="4dp" />
        </LinearLayout>

        <!-- Dynamic Content Stat Row -->
        <TextView
            android:id="@+id/widget_main_stat"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Streak: 3 Days 🔥"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:textStyle="bold"
            android:layout_marginBottom="2dp" />

        <!-- Subtitle Context label -->
        <TextView
            android:id="@+id/widget_subtext"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mochi is keeping you company!"
            android:textColor="#9CA3AF"
            android:textSize="11sp" />

        <!-- Extra tiny details (e.g. Today's focus minutes) -->
        <TextView
            android:id="@+id/widget_detailtext"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Focus today: 42 min"
            android:textColor="#6B7280"
            android:textSize="9.5sp"
            android:layout_marginTop="1dp" />

    </LinearLayout>

</LinearLayout>
